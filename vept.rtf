@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');\
*\{box-sizing:border-box;margin:0;padding:0;\}\
body\{background:#07101F;color:#DCE8F8;font-family:'Plus Jakarta Sans',sans-serif;min-height:100vh;\}\
:root\{--bg:#07101F;--s1:#0D1828;--s2:#132032;--bd:#1E3050;--txt:#DCE8F8;--dim:#5B789E;--acc:#4F9EFF;--grn:#2ED573;--red:#FF4757;--yel:#FFD460;--pur:#B39DDB;\}\
.app\{max-width:860px;margin:0 auto;padding:20px 14px 80px;\}\
.hdr\{text-align:center;padding:40px 0 28px;border-bottom:1px solid var(--bd);margin-bottom:28px;\}\
.htag\{display:inline-block;background:#4F9EFF14;border:1px solid #4F9EFF44;color:var(--acc);font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:2px;padding:5px 15px;border-radius:20px;margin-bottom:16px;\}\
.hdr h1\{font-size:clamp(22px,5vw,40px);font-weight:800;background:linear-gradient(135deg,#DCE8F8 40%,#4F9EFF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.2;margin-bottom:6px;\}\
.hdr p\{color:var(--dim);font-size:13px;\}\
.tabs\{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px;\}\
.tab\{padding:6px 12px;border-radius:8px;border:1px solid var(--bd);background:var(--s1);cursor:pointer;font-size:12px;font-weight:600;transition:all .15s;display:flex;align-items:center;gap:5px;color:var(--dim);\}\
.tab:hover\{border-color:#4F9EFF55;color:var(--txt);\}\
.tab.on\{border-color:var(--pc);background:color-mix(in srgb,var(--pc) 14%,transparent);color:var(--txt);\}\
.dot\{width:6px;height:6px;border-radius:50%;background:var(--pc);flex-shrink:0;\}\
.pct-lbl\{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);\}\
.quiz\{animation:fu .25s ease;\}\
@keyframes fu\{from\{opacity:0;transform:translateY(6px)\}to\{opacity:1;transform:translateY(0)\}\}\
.qhdr\{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px;margin-bottom:14px;\}\
.qtit\{font-size:15px;font-weight:700;\}\
.qmeta\{display:flex;gap:8px;align-items:center;\}\
.sc\{background:var(--s2);border:1px solid var(--bd);border-radius:7px;padding:4px 12px;font-family:'JetBrains Mono',monospace;font-size:11px;display:flex;gap:6px;align-items:center;\}\
.scn\{color:var(--grn);font-size:14px;font-weight:700;\}\
.qct\{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);\}\
.pbar\{height:3px;background:var(--s2);border-radius:2px;margin-bottom:18px;overflow:hidden;\}\
.pfill\{height:100%;border-radius:2px;background:var(--pc);transition:width .3s;\}\
.srow\{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--dim);background:var(--s1);border-radius:8px;padding:8px 12px;margin-bottom:16px;border:1px solid var(--bd);\}\
.sw\{width:34px;height:19px;background:var(--bd);border-radius:10px;cursor:pointer;transition:background .2s;position:relative;flex-shrink:0;\}\
.sw.on\{background:var(--grn);\}\
.sw::after\{content:'';position:absolute;width:13px;height:13px;background:#fff;border-radius:50%;top:3px;left:3px;transition:transform .2s;\}\
.sw.on::after\{transform:translateX(15px);\}\
.card\{background:var(--s1);border:1px solid var(--bd);border-radius:14px;padding:22px;margin-bottom:14px;\}\
.qid\{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);margin-bottom:8px;letter-spacing:1px;\}\
.inst\{font-size:12px;color:var(--dim);background:var(--s2);border-left:3px solid var(--pc);padding:8px 12px;border-radius:0 7px 7px 0;margin-bottom:16px;line-height:1.6;\}\
.qt\{font-size:15px;line-height:1.85;color:var(--txt);background:var(--s2);border-radius:9px;padding:15px 17px;margin-bottom:14px;white-space:pre-wrap;\}\
.qt.blur\{filter:blur(5px);user-select:none;cursor:pointer;\}\
.scram\{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--pur);background:#B39DDB12;border:1px solid #B39DDB33;border-radius:9px;padding:12px 15px;margin-bottom:12px;line-height:1.7;\}\
.dlg\{background:var(--s2);border-radius:9px;padding:13px 16px;margin-bottom:12px;font-size:13px;line-height:1.8;white-space:pre-line;\}\
.qq\{font-size:14px;font-weight:700;color:var(--txt);margin-bottom:12px;\}\
.ft\{font-size:15px;line-height:1.9;margin-bottom:12px;\}\
.blank\{display:inline-block;min-width:80px;border-bottom:2px solid var(--pc);margin:0 3px;vertical-align:bottom;text-align:center;color:var(--pc);font-weight:700;padding:0 5px;\}\
textarea.inp,input.inp\{width:100%;background:var(--s2);border:1px solid var(--bd);border-radius:9px;padding:10px 13px;font-size:13px;color:var(--txt);font-family:'Plus Jakarta Sans',sans-serif;outline:none;transition:border .15s;margin-bottom:10px;resize:vertical;\}\
textarea.inp:focus,input.inp:focus\{border-color:var(--acc);\}\
textarea.inp.ok,input.inp.ok\{border-color:var(--grn);background:#2ED57310;\}\
textarea.inp.err,input.inp.err\{border-color:var(--red);background:#FF475710;\}\
.rev\{background:var(--s2);border-radius:9px;padding:11px 14px;margin-bottom:11px;display:flex;gap:8px;align-items:flex-start;\}\
.rl\{color:var(--dim);font-size:11px;white-space:nowrap;padding-top:2px;flex-shrink:0;\}\
.rv\{color:var(--grn);font-weight:600;font-size:13px;line-height:1.6;\}\
.rv.pur\{color:var(--pur);\}\
.fbk\{margin-top:8px;font-size:12px;font-weight:700;\}\
.fbk.ok\{color:var(--grn);\}\
.fbk.err\{color:var(--red);\}\
.brow\{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px;\}\
.btn\{padding:7px 14px;border:none;border-radius:7px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;transition:all .13s;display:inline-flex;align-items:center;gap:5px;\}\
.btn:disabled\{opacity:.35;cursor:not-allowed;\}\
.bp\{background:var(--acc);color:#030C1A;\}\
.bp:not(:disabled):hover\{filter:brightness(1.1);transform:translateY(-1px);\}\
.bs\{background:var(--s2);color:var(--txt);border:1px solid var(--bd);\}\
.bs:not(:disabled):hover\{border-color:var(--acc);color:var(--acc);\}\
.bspk\{background:linear-gradient(135deg,#1a6b2f,#26a040);color:#fff;\}\
.bspk.ing\{background:linear-gradient(135deg,#7a4e00,#b07200);animation:pls .7s ease infinite;\}\
@keyframes pls\{0%,100%\{opacity:1\}50%\{opacity:.6\}\}\
.bok\{background:var(--grn);color:#030D0A;\}\
.bbad\{background:var(--red);color:#fff;\}\
.nav\{display:flex;justify-content:space-between;align-items:center;margin-top:18px;gap:8px;\}\
.tbr\{height:5px;background:var(--s2);border-radius:3px;margin-bottom:12px;overflow:hidden;\}\
.tf\{height:100%;border-radius:3px;background:var(--grn);transition:width .1s linear;\}\
.tf.w\{background:var(--yel);\}\
.tf.c\{background:var(--red);\}\
.tt\{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);margin-bottom:8px;\}\
.ptm\{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--yel);margin-bottom:9px;\}\
.done\{text-align:center;padding:50px 20px;animation:fu .4s ease;\}\
.dn\{font-family:'JetBrains Mono',monospace;font-size:56px;font-weight:700;color:var(--grn);line-height:1;margin-bottom:8px;\}\
.done h2\{font-size:22px;font-weight:800;margin-bottom:8px;\}\
.done p\{color:var(--dim);margin-bottom:24px;font-size:13px;\}\
@media(max-width:480px)\{.card\{padding:15px 12px;\}.qt\{font-size:14px;\}.btn\{padding:6px 12px;font-size:11px;\}\}\
`;\
\
export default function App() \{\
  const [part,setPart]=useState("A");\
  const [shuf,setShuf]=useState(false);\
  const [qs,setQs]=useState([...QA]);\
  const [qi,setQi]=useState(0);\
  const [showAns,setShowAns]=useState(false);\
  const [inp,setInp]=useState("");\
  const [inp2,setInp2]=useState("");\
  const [chk,setChk]=useState(false);\
  const [ok,setOk]=useState(null);\
  const [spk,setSpk]=useState(false);\
  const [score,setScore]=useState(\{c:0,t:0\});\
  const [done,setDone]=useState(false);\
  const [showTxt,setShowTxt]=useState(true);\
  const [typOn,setTypOn]=useState(false);\
  const [typSec,setTypSec]=useState(60);\
  const typRef=useRef(null);\
  const [pVis,setPVis]=useState(false);\
  const [pSec,setPSec]=useState(30);\
  const [pGone,setPGone]=useState(false);\
  const [wSec,setWSec]=useState(90);\
  const pRef=useRef(null),wRef=useRef(null);\
\
  const pd=PARTS[part];\
  const q=qs[qi];\
\
  useEffect(()=>\{\
    const list=shuf?shuffle(pd.qs):[...pd.qs];\
    setQs(list);setQi(0);reset();setScore(\{c:0,t:0\});setDone(false);\
  \},[part,shuf]);\
\
  function reset()\{\
    setShowAns(false);setInp("");setInp2("");setChk(false);setOk(null);\
    setShowTxt(!["B","G"].includes(part));\
    window.speechSynthesis?.cancel();setSpk(false);\
    clearInterval(typRef.current);setTypOn(false);setTypSec(60);\
    clearInterval(pRef.current);clearInterval(wRef.current);\
    setPVis(false);setPGone(false);setPSec(30);setWSec(90);\
  \}\
\
  function doSpeak(txt,rate=0.85)\{setSpk(true);speak(txt,rate,()=>setSpk(false));\}\
\
  function startTyp()\{\
    setTypOn(true);setTypSec(60);\
    clearInterval(typRef.current);\
    typRef.current=setInterval(()=>setTypSec(s=>\{if(s<=1)\{clearInterval(typRef.current);setTypOn(false);return 0;\}return s-1;\}),1000);\
  \}\
\
  function startPass()\{\
    setPVis(true);setPSec(30);setPGone(false);\
    clearInterval(pRef.current);\
    pRef.current=setInterval(()=>setPSec(s=>\{\
      if(s<=1)\{clearInterval(pRef.current);setPGone(true);setWSec(90);\
        wRef.current=setInterval(()=>setWSec(ws=>\{if(ws<=1)\{clearInterval(wRef.current);return 0;\}return ws-1;\}),1000);\
        return 0;\}return s-1;\}),1000);\
  \}\
\
  function check()\{\
    if(!inp.trim())return;\
    const ans=(q.a||q.text||"").toLowerCase().replace(/[.,!?'"]/g,"").trim();\
    const usr=inp.toLowerCase().replace(/[.,!?'"]/g,"").trim();\
    const good=usr===ans||ans.includes(usr.slice(0,Math.min(8,usr.length)))||usr.includes(ans.slice(0,6));\
    setOk(good);setChk(true);setShowAns(true);\
    setScore(s=>(\{c:s.c+(good?1:0),t:s.t+1\}));\
  \}\
\
  function next()\{if(qi+1>=qs.length)\{setDone(true);return;\}setQi(i=>i+1);reset();\}\
  function prev()\{if(qi===0)return;setQi(i=>i-1);reset();\}\
  function markOk()\{setScore(s=>(\{c:s.c+1,t:s.t+1\}));next();\}\
  function markBad()\{setScore(s=>(\{c:s.c,t:s.t+1\}));next();\}\
  function restart()\{const list=shuf?shuffle(pd.qs):[...pd.qs];setQs(list);setQi(0);reset();setScore(\{c:0,t:0\});setDone(false);\}\
\
  const pct=Math.round((score.c/Math.max(score.t,1))*100);\
  const isOral=["A","B"].includes(part);\
  const needInp=["C","F","G"].includes(part);\
\
  // Format dialogue with line breaks for M:/W: speakers\
  function fmtDlg(s)\{\
    return s.replace(/(M:|W:|\uc0\u30002 :|\u20057 :)/g,'\\n$1').replace(/^\\n/,'');\
  \}\
\
  return(<>\
    <style>\{CSS\}</style>\
    <div className="app">\
      <div className="hdr">\
        <div className="htag">VEPT \uc0\u32508 \u21512 \u39064 \u24211 \u32451 \u20064 \u31995 \u32479 </div>\
        <h1>Versant English Proficiency Test</h1>\
        <p>\uc0\u20840 9\u22823 \u39064 \u22411 \u23436 \u25972 \u39064 \u24211  \'b7 B\u37096 <strong>276</strong>\u39064  \'b7 C\u37096 <strong>154</strong>\u39064  \'b7 D\u37096 <strong>91</strong>\u39064  \'b7 F\u37096 <strong>50</strong>\u39064  \'b7 G\u37096 <strong>176</strong>\u39064  \'b7 \u20840 \u31243 \u35821 \u38899 \u25903 \u25345 </p>\
      </div>\
\
      <div className="tabs">\
        \{Object.entries(PARTS).map(([k,p])=>(\
          <div key=\{k\} className=\{`tab $\{part===k?"on":""\}`\} style=\{\{"--pc":p.color\}\} onClick=\{()=>setPart(k)\}>\
            <span className="dot"/><span>\{p.icon\} \{p.label\}</span><span className="pct-lbl">\{p.pct\}</span>\
          </div>\
        ))\}\
      </div>\
\
      \{!done?(\
        <div className="quiz" style=\{\{"--pc":pd.color\}\}>\
          <div className="qhdr">\
            <div className="qtit">\{pd.icon\} \{pd.name\}</div>\
            <div className="qmeta">\
              <div className="sc"><span className="scn">\{score.c\}</span>/\{score.t\} \uc0\u31572 \u23545 </div>\
              <div className="qct">\{qi+1\}/\{qs.length\}</div>\
            </div>\
          </div>\
          <div className="pbar"><div className="pfill" style=\{\{width:`$\{(qi/qs.length)*100\}%`\}\}/></div>\
\
          <div className="srow">\
            <div className=\{`sw $\{shuf?"on":""\}`\} onClick=\{()=>setShuf(s=>!s)\}/>\
            <span>\uc0\u38543 \u26426 \u39034 \u24207  \{shuf?"\u10003  \u24050 \u24320 \u21551 ":"\u65288 \u20851 \u38381 \u65289 "\}</span>\
            <span style=\{\{marginLeft:"auto",fontSize:11,color:"var(--dim)"\}\}>\uc0\u20849 \{qs.length\}\u39064 </span>\
          </div>\
\
          <div className="card">\
            <div className="qid">\{q.id\} \'b7 \{pd.label\}</div>\
            <div className="inst">\{pd.inst\}</div>\
\
            \{part==="A"&&<>\
              <div className="qt">\{q.text\}</div>\
              <div className="brow">\
                <button className=\{`btn bspk $\{spk?"ing":""\}`\} onClick=\{()=>doSpeak(q.text,0.8)\}>\{spk?"\uc0\u55357 \u56586  \u25773 \u25918 \u20013 ...":"\u55357 \u56586  \u25773 \u25918 \u33539 \u35835 "\}</button>\
                <button className="btn bs" onClick=\{()=>doSpeak(q.text,0.62)\}>\uc0\u55357 \u56354  \u24930 \u36895 </button>\
              </div>\
            </>\}\
\
            \{part==="B"&&<>\
              <div className=\{`qt $\{!showTxt?"blur":""\}`\} onClick=\{()=>!showTxt&&setShowTxt(true)\}>\{q.text\}</div>\
              <div className="brow">\
                <button className=\{`btn bspk $\{spk?"ing":""\}`\} onClick=\{()=>\{setShowTxt(false);doSpeak(q.text,0.82);\}\}>\{spk?"\uc0\u55357 \u56586  \u25773 \u25918 \u20013 ...":"\u55357 \u56586  \u21548 \u21477 \u23376 \u65288 \u38544 \u34255 \u25991 \u23383 \u65289 "\}</button>\
                <button className="btn bs" onClick=\{()=>setShowTxt(s=>!s)\}>\{showTxt?"\uc0\u55357 \u56904  \u38544 \u34255 ":"\u55357 \u56385  \u26174 \u31034 "\}</button>\
              </div>\
            </>\}\
\
            \{part==="C"&&<>\
              <div className="scram">\uc0\u55357 \u56576  \u35789 \u32452 \u65306 \{q.s\}</div>\
              <div className="brow" style=\{\{marginBottom:12\}\}>\
                <button className=\{`btn bspk $\{spk?"ing":""\}`\} onClick=\{()=>doSpeak(q.s.replace(/\\//g,","),0.8)\}>\{spk?"\uc0\u55357 \u56586  \u25773 \u25918 \u20013 ...":"\u55357 \u56586  \u21548 \u35789 \u32452 "\}</button>\
              </div>\
              \{!showAns&&<>\
                <textarea className=\{`inp $\{chk?(ok?"ok":"err"):""\}`\} rows=\{2\} placeholder="\uc0\u23558 \u35789 \u32452 \u25490 \u21015 \u25104 \u27491 \u30830 \u21477 \u23376 ..." value=\{inp\} onChange=\{e=>setInp(e.target.value)\} onKeyDown=\{e=>\{if(e.key==="Enter"&&!e.shiftKey)\{e.preventDefault();check();\}\}\}/>\
                <div className="brow">\
                  <button className="btn bp" onClick=\{check\}>\uc0\u10003  \u26816 \u26597 \u31572 \u26696 </button>\
                  <button className="btn bs" onClick=\{()=>setShowAns(true)\}>\uc0\u55357 \u56385  \u30452 \u25509 \u26597 \u30475 </button>\
                </div>\
              </>\}\
              \{showAns&&<div className="rev"><span className="rl">\uc0\u9989  \u31572 \u26696 \u65306 </span><span className="rv">\{q.a\}</span></div>\}\
              \{chk&&<div className=\{`fbk $\{ok?"ok":"err"\}`\}>\{ok?"\uc0\u55356 \u57225  \u22238 \u31572 \u27491 \u30830 \u65281 ":"\u10060  \u31572 \u26696 \u26377 \u35823 "\}</div>\}\
              \{showAns&&<div className="brow" style=\{\{marginTop:10\}\}><button className="btn bspk" onClick=\{()=>doSpeak(q.a)\}>\uc0\u55357 \u56586  \u21548 \u27491 \u30830 \u31572 \u26696 </button></div>\}\
            </>\}\
\
            \{part==="D"&&<>\
              <div className="dlg">\{fmtDlg(q.dlg)\}</div>\
              <div className="qq">\uc0\u10067  \{q.q\}</div>\
              <div className="brow" style=\{\{marginBottom:12\}\}>\
                <button className=\{`btn bspk $\{spk?"ing":""\}`\} onClick=\{()=>doSpeak(q.dlg,0.85)\}>\{spk?"\uc0\u55357 \u56586  \u25773 \u25918 \u20013 ...":"\u55357 \u56586  \u21548 \u23545 \u35805 "\}</button>\
                <button className="btn bs" onClick=\{()=>doSpeak(q.q)\}>\uc0\u55357 \u56586  \u21548 \u38382 \u39064 </button>\
              </div>\
              \{!showAns&&<>\
                <input className="inp" type="text" placeholder="\uc0\u36755 \u20837 \u20851 \u38190 \u35789 \u31572 \u26696 ..." value=\{inp\} onChange=\{e=>setInp(e.target.value)\} onKeyDown=\{e=>\{if(e.key==="Enter")setShowAns(true);\}\}/>\
                <div className="brow"><button className="btn bp" onClick=\{()=>setShowAns(true)\}>\uc0\u10003  \u26597 \u30475 \u31572 \u26696 </button></div>\
              </>\}\
              \{showAns&&<div className="rev"><span className="rl">\uc0\u9989  \u21442 \u32771 \u31572 \u26696 \u65306 </span><span className="rv">\{q.a\}</span></div>\}\
            </>\}\
\
            \{part==="E"&&<>\
              <div className="qt">\{q.text\}</div>\
              \{!typOn&&typSec===60&&<div className="brow" style=\{\{marginBottom:12\}\}><button className="btn bp" onClick=\{startTyp\}>\uc0\u9201  \u24320 \u22987 \u35745 \u26102 \u65288 60\u31186 \u65289 </button></div>\}\
              \{(typOn||typSec<60)&&<>\
                <div className="tt">\uc0\u21097 \u20313 \u65306 \{typSec\}\u31186 </div>\
                <div className="tbr"><div className=\{`tf $\{typSec<20?"c":typSec<35?"w":""\}`\} style=\{\{width:`$\{(typSec/60)*100\}%`\}\}/></div>\
              </>\}\
              <textarea className="inp" rows=\{4\} placeholder="\uc0\u35831 \u22312 \u27492 \u36755 \u20837 \u20320 \u30475 \u21040 \u30340 \u25991 \u23383 \u65292 \u36234 \u24555 \u36234 \u22909 ..." value=\{inp\} onChange=\{e=>setInp(e.target.value)\}/>\
              \{typSec===0&&<div className="fbk ok">\uc0\u9200  \u26102 \u38388 \u21040 \u65281 \u20849 \u36755 \u20837  \{inp.split(/\\s+/).filter(Boolean).length\} \u20010 \u21333 \u35789 </div>\}\
            </>\}\
\
            \{part==="F"&&<>\
              <div className="brow" style=\{\{marginBottom:12\}\}>\
                <button className=\{`btn bspk $\{spk?"ing":""\}`\} onClick=\{()=>doSpeak(q.t.replace("_____","blank"),0.85)\}>\{spk?"\uc0\u55357 \u56586  \u25773 \u25918 \u20013 ...":"\u55357 \u56586  \u21548 \u21477 \u23376 "\}</button>\
              </div>\
              <div className="ft">\
                \{q.t.split("_____").map((seg,i,arr)=>(\
                  <span key=\{i\}>\{seg\}\{i<arr.length-1&&<span className="blank">\{showAns?q.a:"___"\}</span>\}</span>\
                ))\}\
              </div>\
              \{!showAns&&<>\
                <input className=\{`inp $\{chk?(ok?"ok":"err"):""\}`\} type="text" placeholder="\uc0\u22635 \u20889 \u32570 \u22833 \u30340 \u21333 \u35789 ..." value=\{inp\} onChange=\{e=>setInp(e.target.value)\} onKeyDown=\{e=>\{if(e.key==="Enter")check();\}\}/>\
                <div className="brow">\
                  <button className="btn bp" onClick=\{check\}>\uc0\u10003  \u26816 \u26597 </button>\
                  <button className="btn bs" onClick=\{()=>setShowAns(true)\}>\uc0\u55357 \u56385  \u26597 \u30475 \u31572 \u26696 </button>\
                </div>\
              </>\}\
              \{showAns&&<><div className="rev"><span className="rl">\uc0\u31572 \u26696 \u65306 </span><span className="rv">\{q.a\}</span></div>\
                <div className="brow"><button className="btn bspk" onClick=\{()=>doSpeak(q.t.replace("_____",q.a))\}>\uc0\u55357 \u56586  \u21548 \u23436 \u25972 \u21477 \u23376 </button></div>\
              </>\}\
              \{chk&&<div className=\{`fbk $\{ok?"ok":"err"\}`\}>\{ok?"\uc0\u55356 \u57225  \u27491 \u30830 \u65281 ":"\u10060  \u31572 \u26696 \u26377 \u35823 "\}</div>\}\
            </>\}\
\
            \{part==="G"&&<>\
              <div className="brow" style=\{\{marginBottom:12\}\}>\
                <button className=\{`btn bspk $\{spk?"ing":""\}`\} onClick=\{()=>\{setShowTxt(false);doSpeak(q.text,0.8);\}\}>\{spk?"\uc0\u55357 \u56586  \u25773 \u25918 \u20013 ...":"\u55357 \u56586  \u21548 \u21477 \u23376 \u65288 \u38544 \u34255 \u25991 \u23383 \u65289 "\}</button>\
                <button className="btn bs" onClick=\{()=>doSpeak(q.text,0.62)\}>\uc0\u55357 \u56354  \u24930 \u36895 \u20877 \u21548 </button>\
                <button className="btn bs" onClick=\{()=>setShowTxt(s=>!s)\}>\{showTxt?"\uc0\u55357 \u56904  \u38544 \u34255 \u21407 \u21477 ":"\u55357 \u56385  \u26174 \u31034 \u21407 \u21477 "\}</button>\
              </div>\
              \{showTxt&&<div className="qt">\{q.text\}</div>\}\
              \{!showAns&&<>\
                <textarea className=\{`inp $\{chk?(ok?"ok":"err"):""\}`\} rows=\{2\} placeholder="\uc0\u25340 \u20889 \u24744 \u21548 \u21040 \u30340 \u21477 \u23376 \u65288 \u27880 \u24847 \u22823 \u23567 \u20889 \u21644 \u26631 \u28857 \u65289 ..." value=\{inp\} onChange=\{e=>setInp(e.target.value)\} onKeyDown=\{e=>\{if(e.key==="Enter"&&!e.shiftKey)\{e.preventDefault();check();\}\}\}/>\
                <div className="brow">\
                  <button className="btn bp" onClick=\{check\}>\uc0\u10003  \u26680 \u23545 </button>\
                  <button className="btn bs" onClick=\{()=>\{setShowAns(true);setShowTxt(true);\}\}>\uc0\u55357 \u56385  \u26174 \u31034 \u21407 \u21477 </button>\
                </div>\
              </>\}\
              \{showAns&&<div className="rev"><span className="rl">\uc0\u9989  \u21407 \u21477 \u65306 </span><span className="rv">\{q.text\}</span></div>\}\
              \{chk&&<div className=\{`fbk $\{ok?"ok":"err"\}`\}>\{ok?"\uc0\u55356 \u57225  \u23436 \u20840 \u27491 \u30830 \u65281 ":"\u10060  \u26377 \u35823 \u65292 \u35831 \u30475 \u21407 \u21477 "\}</div>\}\
            </>\}\
\
            \{part==="H"&&<>\
              \{!pVis&&!pGone&&<div className="brow" style=\{\{marginBottom:12\}\}><button className="btn bp" onClick=\{startPass\}>\uc0\u9654  \u24320 \u22987 \u38405 \u35835 \u65288 30\u31186 \u35745 \u26102 \u65289 </button></div>\}\
              \{pVis&&!pGone&&<><div className="ptm">\uc0\u9201  \u38405 \u35835 \u26102 \u38388 \u65306 \{pSec\}\u31186 \u65288 \u35831 \u35748 \u30495 \u38405 \u35835 \u65289 </div><div className="qt">\{q.passage\}</div></>\}\
              \{pGone&&<>\
                <div className="ptm">\uc0\u9997 \u65039  \u20889 \u20316 \u26102 \u38388 \u21097 \u20313 \u65306 \{wSec\}\u31186 \u65288 \u21407 \u25991 \u24050 \u28040 \u22833 \u65289 </div>\
